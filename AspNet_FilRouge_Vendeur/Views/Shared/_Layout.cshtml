<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Les Bleus - Vendeur</title>
    <link rel="stylesheet" href="~/Content/bootstrap.css" />
    <link rel="stylesheet" href="~/Content/Site.css" />
</head>
<body>
    <div id="sync-status" class="text-right" style="background:#f5f5f5;padding:2px 15px;font-size:12px;border-bottom:1px solid #ddd;">
        <span id="online-indicator">🟢 En ligne</span>
    </div>
    <nav class="navbar navbar-dark navbar-expand-lg fixed-top" style="background-color: #2f558c;">
        <div class="container">
            <button type="button" class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">@Html.ActionLink("Accueil", "Index", "Home", routeValues: null, htmlAttributes: new { @class = "nav-link" })</li>
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">@Html.ActionLink("Stock", "Index", "Bicycles", routeValues: null, htmlAttributes: new { @class = "nav-link" })</li>
                        <li class="nav-item">@Html.ActionLink("Commandes", "Index", "Orders", routeValues: null, htmlAttributes: new { @class = "nav-link" })</li>
                        <li class="nav-item">@Html.ActionLink("Demandes de stock", "Index", "StockRequests", routeValues: null, htmlAttributes: new { @class = "nav-link" })</li>
                        @if (User.IsInRole("Administrateur"))
                        {
                            <li class="nav-item">@Html.ActionLink("Vendeurs", "Index", "Sellers", routeValues: null, htmlAttributes: new { @class = "nav-link" })</li>
                            <li class="nav-item">@Html.ActionLink("Rôles", "Index", "Role", routeValues: null, htmlAttributes: new { @class = "nav-link" })</li>
                            <li class="nav-item">@Html.ActionLink("Synchronisation", "Index", "SyncManagement", routeValues: null, htmlAttributes: new { @class = "nav-link" })</li>
                        }
                    }
                </ul>
                @await Html.PartialAsync("_LoginPartial")
            </div>
        </div>
    </nav>
    <div>
        <div class="container body-content">
            @RenderBody()
            <hr />
            <footer>
                <div class="col-10 col-md-10 col-lg-10">
                    <p>&copy; @DateTime.Now.Year - Allez les bleus !</p>
                </div>
                <div class="col-2 col-md-2 col-lg-2">
                    <p>@DateTime.Now.ToString()</p>
                </div>
            </footer>
        </div>
    </div>

    <script src="~/Scripts/jquery-3.7.1.min.js"></script>
    <script src="~/Scripts/bootstrap.js"></script>
    <script>
        // Indicateur de connectivité global
        function updateGlobalOnlineStatus() {
            var indicator = document.getElementById('online-indicator');
            if (!indicator) return;
            if (navigator.onLine) {
                indicator.textContent = '🟢 En ligne';
                indicator.style.color = 'green';
            } else {
                indicator.textContent = '🔴 Hors-ligne — validation de commande désactivée';
                indicator.style.color = 'red';
            }
        }
        window.addEventListener('online',  updateGlobalOnlineStatus);
        window.addEventListener('offline', updateGlobalOnlineStatus);
        updateGlobalOnlineStatus();
    </script>
    @RenderSection("scripts", required: false)
</body>
</html>
