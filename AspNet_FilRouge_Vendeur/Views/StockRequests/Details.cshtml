@model Entities.StockRequest

@{
    ViewBag.Title = "Détails de la demande";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var canManage = User.IsInRole("Administrateur") || Model.RequestedById == currentUserId;
}

<h2>Détails de la demande</h2>

<div>
    <hr />
    <dl class="row">
        <dt class="col-md-3">@Html.DisplayNameFor(model => model.BicycleName)</dt>
        <dd class="col-md-9">@Html.DisplayFor(model => model.BicycleName)</dd>

        <dt class="col-md-3">@Html.DisplayNameFor(model => model.Quantity)</dt>
        <dd class="col-md-9">@Html.DisplayFor(model => model.Quantity)</dd>

        <dt class="col-md-3">@Html.DisplayNameFor(model => model.RequestDate)</dt>
        <dd class="col-md-9">@Model.RequestDate.ToString("dd/MM/yyyy HH:mm")</dd>

        <dt class="col-md-3">@Html.DisplayNameFor(model => model.Status)</dt>
        <dd class="col-md-9">
            @if (Model.Status == "Approuvée")
            {
                <span class="badge bg-success">@Model.Status</span>
            }
            else if (Model.Status == "Rejetée")
            {
                <span class="badge bg-danger">@Model.Status</span>
            }
            else
            {
                <span class="badge bg-warning text-dark">@Model.Status</span>
            }
        </dd>

        <dt class="col-md-3">@Html.DisplayNameFor(model => model.RequestedBy)</dt>
        <dd class="col-md-9">
            @if (Model.RequestedBy != null)
            {
                @($"{Model.RequestedBy.FirstName} {Model.RequestedBy.LastName}")
            }
        </dd>

        <dt class="col-md-3">@Html.DisplayNameFor(model => model.Notes)</dt>
        <dd class="col-md-9">@Html.DisplayFor(model => model.Notes)</dd>
    </dl>
</div>

@if (User.IsInRole("Administrateur") && Model.Status == "En attente")
{
    <div class="mt-3">
        @using (Html.BeginForm("Approve", "StockRequests", new { id = Model.Id }, FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-success">Approuver</button>
        }
        @Html.Raw(" ")
        @using (Html.BeginForm("Reject", "StockRequests", new { id = Model.Id }, FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger">Rejeter</button>
        }
    </div>
}

<div class="mt-3">
    @if (canManage && Model.Status == "En attente")
    {
        @Html.ActionLink("Modifier", "Edit", new { id = Model.Id }, new { @class = "btn btn-primary" })
        @Html.Raw(" ")
        @Html.ActionLink("Supprimer", "Delete", new { id = Model.Id }, new { @class = "btn btn-outline-danger" })
        @Html.Raw(" ")
    }
    @Html.ActionLink("Retour à la liste", "Index")
</div>
