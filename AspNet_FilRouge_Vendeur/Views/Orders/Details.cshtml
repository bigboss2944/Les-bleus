@model Entities.Order

@{
    ViewBag.Title = "Détails commande";
    Layout = "~/Views/Shared/_Layout.cshtml";

    float subtotal = Model.Bicycles?.Sum(b => b.FreeTaxPrice) ?? 0f;
    float afterDiscount = subtotal * (1 - Model.Discount / 100f);
    float total = afterDiscount * (1 + Model.Tax / 100f) + Model.ShippingCost;
}

<h2>Détails commande #@Model.IdOrder</h2>

<div class="row">
    <div class="col-md-6">
        <h4>Informations</h4>
        <dl class="dl-horizontal">
            <dt>Date</dt>
            <dd>@Model.Date.ToString("dd/MM/yyyy HH:mm")</dd>

            <dt>Vendeur</dt>
            <dd>@(Model.Seller != null ? $"{Model.Seller.FirstName} {Model.Seller.LastName}" : "—")</dd>

            <dt>Client</dt>
            <dd>@(Model.Customer != null ? $"{Model.Customer.FirstName} {Model.Customer.LastName}" : "—")</dd>

            <dt>Boutique</dt>
            <dd>@(Model.Shop?.Name ?? "—")</dd>

            <dt>Mode paiement</dt>
            <dd>@(Model.PayMode ?? "—")</dd>

            <dt>Remise</dt>
            <dd>@Model.Discount %</dd>

            <dt>TVA</dt>
            <dd>@Model.Tax %</dd>

            <dt>Frais de livraison</dt>
            <dd>@Model.ShippingCost.ToString("F2") €</dd>

            <dt>Points fidélité</dt>
            <dd>@(Model.UseLoyaltyPoint ? "Oui" : "Non")</dd>

            <dt>Statut</dt>
            <dd>
                @if (Model.IsValidated)
                {
                    <span class="label label-success">Validée</span>
                }
                else
                {
                    <span class="label label-default">En cours</span>
                }
            </dd>
        </dl>
    </div>

    <div class="col-md-6">
        <h4>Produits</h4>
        @if (Model.Bicycles != null && Model.Bicycles.Any())
        {
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Référence</th>
                        <th>Catégorie</th>
                        <th>Marque</th>
                        <th>Prix HT (€)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in Model.Bicycles)
                    {
                        <tr>
                            <td>@b.Reference</td>
                            <td>@b.Category</td>
                            <td>@b.Brand</td>
                            <td>@b.FreeTaxPrice.ToString("F2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted">Aucun produit dans cette commande.</p>
        }

        @if (!Model.IsValidated)
        {
            <p class="text-muted small">Ajout/retrait des produits disponible dans la page de modification.</p>
        }
    </div>
</div>

<hr />
<div class="row">
    <div class="col-md-6">
        <h4>Total : <span id="total-price" class="text-success">@total.ToString("F2") €</span></h4>
    </div>
</div>

<p>
    @if (!Model.IsValidated)
    {
        @Html.ActionLink("Modifier", "Edit", new { id = Model.IdOrder }, new { @class = "btn btn-secondary" })
        <text> </text>
        @Html.ActionLink("Supprimer", "Delete", new { id = Model.IdOrder }, new { @class = "btn btn-danger" })
        <text> </text>

        @if (User.IsInRole("Administrateur"))
        {
            <button type="button" id="btn-validate" class="btn btn-success"
                    onclick="validateOrder(@Model.IdOrder)">
                Valider la commande
            </button>
            <text> </text>
        }
    }
    @Html.ActionLink("Retour à la liste", "Index", null, new { @class = "btn btn-link" })
</p>

@Html.AntiForgeryToken()

@section scripts {
<script>
    var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';

    function updateValidateButtonOnlineState() {
        var btn = document.getElementById('btn-validate');
        if (!btn) return;

        var isOnline = navigator.onLine;
        btn.disabled = !isOnline;
        btn.title = isOnline ? '' : 'Validation impossible en mode hors-ligne';
    }

    window.addEventListener('online', updateValidateButtonOnlineState);
    window.addEventListener('offline', updateValidateButtonOnlineState);
    updateValidateButtonOnlineState();

    function validateOrder(oId) {
        if (!navigator.onLine) {
            alert('Validation impossible en mode hors-ligne.');
            updateValidateButtonOnlineState();
            return;
        }

        if (!confirm('Valider cette commande ? Cette action est irréversible.')) return;
        var btn = document.getElementById('btn-validate');
        if (!btn) return;

        btn.disabled = true;
        btn.textContent = 'En cours…';

        fetch('@Url.Action("Validate", "Orders")/' + oId, {
            method: 'POST',
            headers: {
                'RequestVerificationToken': token,
                'X-Client-Online': String(navigator.onLine)
            }
        })
        .then(r => r.json())
        .then(data => {
            if (data.error) {
                alert(data.error);
                btn.disabled = false;
                btn.textContent = 'Valider la commande';
            } else {
                location.reload();
            }
        })
        .catch(function() {
            alert('Erreur réseau. Veuillez réessayer.');
            btn.disabled = false;
            btn.textContent = 'Valider la commande';
        });
    }

</script>
}
