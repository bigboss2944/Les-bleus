@model Entities.Order

@{
    ViewBag.Title = "Modifier la commande";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Modifier la commande #@Model.IdOrder</h2>

@using (Html.BeginForm("Edit", "Orders", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(model => model.IdOrder)

    <div class="form-horizontal">
        <hr />
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <div class="row mb-3">
            @Html.LabelFor(model => model.Date, "Date", htmlAttributes: new { @class = "col-md-2 col-form-label" })
            <div class="col-md-10">
                @Html.EditorFor(model => model.Date, new { htmlAttributes = new { @class = "form-control" } })
            </div>
        </div>

        <div class="row mb-3">
            @Html.LabelFor(model => model.PayMode, "Mode de paiement", htmlAttributes: new { @class = "col-md-2 col-form-label" })
            <div class="col-md-10">
                <select name="PayMode" class="form-control">
                    <option value="">— Choisir —</option>
                    @foreach (var pm in new[] { "Carte bancaire", "Espèces", "Virement", "Chèque" })
                    {
                        if (Model.PayMode == pm)
                        {
                            <option selected>@pm</option>
                        }
                        else
                        {
                            <option>@pm</option>
                        }
                    }
                </select>
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-md-2 col-form-label">Client</label>
            <div class="col-md-10">
                <select name="CustomerId" class="form-control">
                    <option value="">— Aucun —</option>
                    @foreach (var c in (List<Entities.Customer>)ViewBag.Customers)
                    {
                        if (Model.Customer?.Id == c.Id)
                        {
                            <option value="@c.Id" selected>@c.FirstName @c.LastName</option>
                        }
                        else
                        {
                            <option value="@c.Id">@c.FirstName @c.LastName</option>
                        }
                    }
                </select>
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-md-2 col-form-label">Boutique</label>
            <div class="col-md-10">
                <select name="ShopId" class="form-control">
                    <option value="">— Aucune —</option>
                    @foreach (var s in (List<Entities.Shop>)ViewBag.Shops)
                    {
                        if (Model.Shop?.ShopId == s.ShopId)
                        {
                            <option value="@s.ShopId" selected>@s.Nameshop</option>
                        }
                        else
                        {
                            <option value="@s.ShopId">@s.Nameshop</option>
                        }
                    }
                </select>
            </div>
        </div>

        <div class="row mb-3">
            @Html.LabelFor(model => model.Discount, "Remise (%)", htmlAttributes: new { @class = "col-md-2 col-form-label" })
            <div class="col-md-10">
                @Html.EditorFor(model => model.Discount, new { htmlAttributes = new { @class = "form-control price-input", id = "Discount" } })
            </div>
        </div>

        <div class="row mb-3">
            @Html.LabelFor(model => model.Tax, "TVA (%)", htmlAttributes: new { @class = "col-md-2 col-form-label" })
            <div class="col-md-10">
                @Html.EditorFor(model => model.Tax, new { htmlAttributes = new { @class = "form-control price-input", id = "Tax" } })
            </div>
        </div>

        <div class="row mb-3">
            @Html.LabelFor(model => model.ShippingCost, "Frais de livraison (€)", htmlAttributes: new { @class = "col-md-2 col-form-label" })
            <div class="col-md-10">
                @Html.EditorFor(model => model.ShippingCost, new { htmlAttributes = new { @class = "form-control price-input", id = "ShippingCost" } })
            </div>
        </div>

        <div class="row mb-3">
            @Html.LabelFor(model => model.UseLoyaltyPoint, "Points fidélité", htmlAttributes: new { @class = "col-md-2 col-form-label" })
            <div class="col-md-10 pt-2">
                <div class="form-check">
                    @Html.CheckBoxFor(model => model.UseLoyaltyPoint, new { @class = "form-check-input" })
                </div>
            </div>
        </div>

        <hr />
        <h4>Produits actuels</h4>
        @if (Model.Bicycles != null && Model.Bicycles.Any())
        {
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Référence</th>
                        <th>Catégorie</th>
                        <th>Prix HT (€)</th>
                        <th>Retirer</th>
                    </tr>
                </thead>
                <tbody id="bicycle-list">
                    @foreach (var b in Model.Bicycles)
                    {
                        <tr id="row-@b.Id">
                            <td>@b.Reference</td>
                            <td>@b.Category</td>
                            <td>@b.FreeTaxPrice.ToString("F2")</td>
                            <td>
                                <button type="button" class="btn btn-xs btn-danger"
                                        onclick="removeBicycle(@Model.IdOrder, @b.Id, this)">
                                    Retirer
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        <h5>Ajouter un vélo</h5>
        <div class="input-group" style="max-width:400px;">
            <select id="add-bicycle-id" class="form-control">
                <option value="">-- Choisir une référence --</option>
                @{
                    var currentBicycleIds = new HashSet<long>((Model.Bicycles ?? new List<Entities.Bicycle>()).Select(b => b.Id));
                    var bicyclesForDropdown = ((IEnumerable<Entities.Bicycle>?)ViewBag.Bicycles ?? Enumerable.Empty<Entities.Bicycle>())
                        .Where(b => b.Quantity > 0 && !currentBicycleIds.Contains(b.Id))
                        .OrderBy(b => b.Reference)
                        .ThenBy(b => b.Id)
                        .ToList();
                }
                @foreach (var bicycle in bicyclesForDropdown)
                {
                    var referenceLabel = string.IsNullOrWhiteSpace(bicycle.Reference)
                        ? $"Velo #{bicycle.Id}"
                        : bicycle.Reference;
                    var categoryLabel = string.IsNullOrWhiteSpace(bicycle.Category)
                        ? "Sans categorie"
                        : bicycle.Category;
                    <option value="@bicycle.Id">@referenceLabel (@categoryLabel)</option>
                }
                @if (!bicyclesForDropdown.Any())
                {
                    <option value="" disabled>Aucun produit disponible</option>
                }
            </select>
            <button type="button" class="btn btn-secondary" onclick="addBicycle(@Model.IdOrder, this)">
                Ajouter
            </button>
        </div>

        <hr />
        <div class="row mb-3">
            <label class="col-md-2 col-form-label">Total estimé</label>
            <div class="col-md-10">
                <h3 id="total-price" class="text-success">
                    @{
                        float subtotal = Model.Bicycles?.Sum(b => b.FreeTaxPrice) ?? 0f;
                        float afterDiscount = subtotal * (1 - Model.Discount / 100f);
                        float total = afterDiscount * (1 + Model.Tax / 100f) + Model.ShippingCost;
                    }
                    @total.ToString("F2") €
                </h3>
            </div>
        </div>

        <div class="row mb-3">
            <div class="offset-md-2 col-md-10">
                <input type="submit" value="Enregistrer" class="btn btn-primary" />
            </div>
        </div>
    </div>
}

<div>
    @Html.ActionLink("Retour à la liste", "Index") |
    @Html.ActionLink("Voir les détails", "Details", new { id = Model.IdOrder })
</div>

@section scripts {
<script>
    var orderId = @Model.IdOrder;
    var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
    var bicyclePrices = [@string.Join(",", (Model.Bicycles ?? new List<Entities.Bicycle>()).Select(b => b.FreeTaxPrice.ToString(System.Globalization.CultureInfo.InvariantCulture)))];

    function recalcTotal() {
        var subtotal = bicyclePrices.reduce(function(a, b) { return a + b; }, 0);
        var discount = parseFloat(document.getElementById('Discount')?.value) || 0;
        var tax      = parseFloat(document.getElementById('Tax')?.value)      || 0;
        var shipping = parseFloat(document.getElementById('ShippingCost')?.value) || 0;

        var afterDiscount = subtotal * (1 - discount / 100);
        var withTax       = afterDiscount * (1 + tax / 100);
        var total         = withTax + shipping;

        document.getElementById('total-price').textContent = total.toLocaleString('fr-FR', {minimumFractionDigits: 2, maximumFractionDigits: 2}) + ' €';
    }

    document.querySelectorAll('.price-input').forEach(function(el) {
        el.addEventListener('change', recalcTotal);
        el.addEventListener('input',  recalcTotal);
    });

    function parseApiResponse(response) {
        var contentType = response.headers.get('content-type') || '';
        if (contentType.indexOf('application/json') >= 0) {
            return response.json().then(function(data) {
                if (!response.ok) {
                    throw new Error(data && data.error ? data.error : ('Erreur ' + response.status));
                }
                return data;
            });
        }

        if (!response.ok) {
            throw new Error('Erreur ' + response.status + '. Veuillez recharger la page.');
        }

        return Promise.resolve({});
    }

    function addBicycle(oId, btn) {
        var bicycleId = document.getElementById('add-bicycle-id').value;
        if (!bicycleId) { alert('Veuillez sélectionner une référence produit.'); return; }

        btn.disabled = true;
        btn.textContent = 'En cours...';

        fetch('@Url.Action("AddBicycle", "Orders")?orderId=' + oId + '&bicycleId=' + bicycleId, {
            method: 'POST',
            headers: { 'RequestVerificationToken': token }
        })
        .then(parseApiResponse)
        .then(data => {
            if (data.error) {
                alert(data.error);
                btn.disabled = false;
                btn.textContent = 'Ajouter';
            } else {
                location.reload();
            }
        })
        .catch(function(error) {
            alert(error && error.message ? error.message : 'Erreur réseau. Veuillez réessayer.');
            btn.disabled = false;
            btn.textContent = 'Ajouter';
        });
    }

    function removeBicycle(oId, bId, btn) {
        if (!confirm('Retirer ce vélo de la commande ?')) return;

        btn.disabled = true;
        fetch('@Url.Action("RemoveBicycle", "Orders")?orderId=' + oId + '&bicycleId=' + bId, {
            method: 'POST',
            headers: { 'RequestVerificationToken': token }
        })
        .then(parseApiResponse)
        .then(data => {
            if (data.error) {
                alert(data.error);
                btn.disabled = false;
            } else {
                location.reload();
            }
        })
        .catch(function(error) {
            alert(error && error.message ? error.message : 'Erreur réseau. Veuillez réessayer.');
            btn.disabled = false;
        });
    }
</script>
}
