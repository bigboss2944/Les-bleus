@model AspNet_FilRouge_Vendeur.Models.PaginatedList<AspNet_FilRouge_Vendeur.Models.Order>

@{
    ViewBag.Title = "Commandes";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Commandes</h2>

<form method="get" action="@Url.Action("Index", "Orders")" class="mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-auto">
            <label for="sellerId" class="form-label">Filtrer par vendeur</label>
            <select id="sellerId" name="sellerId" class="form-select">
                <option value="">-- Tous les vendeurs --</option>
                @foreach (var seller in (IEnumerable<AspNet_FilRouge_Vendeur.Models.Seller>)ViewBag.Sellers)
                {
                    if (seller.Id == (ViewBag.CurrentSellerId as string))
                    {
                        <option value="@seller.Id" selected="selected">@seller.LastName @seller.FirstName</option>
                    }
                    else
                    {
                        <option value="@seller.Id">@seller.LastName @seller.FirstName</option>
                    }
                }
            </select>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">Filtrer</button>
            @if (!string.IsNullOrEmpty(ViewBag.CurrentSellerId as string))
            {
                <a href="@Url.Action("Index", "Orders")" class="btn btn-secondary ms-2">Réinitialiser</a>
            }
        </div>
    </div>
</form>

<table class="table table-striped">
    <tr>
        <th>Date</th>
        <th>Vendeur</th>
        <th>Mode de paiement</th>
        <th>Remise</th>
        <th>Taxe</th>
        <th>Frais de livraison</th>
        <th>Actions</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@Html.DisplayFor(modelItem => item.Date)</td>
            <td>@(item.Seller != null ? $"{item.Seller.LastName} {item.Seller.FirstName}" : "-")</td>
            <td>@Html.DisplayFor(modelItem => item.PayMode)</td>
            <td>@Html.DisplayFor(modelItem => item.Discount)</td>
            <td>@Html.DisplayFor(modelItem => item.Tax)</td>
            <td>@Html.DisplayFor(modelItem => item.ShippingCost)</td>
            <td>
                @Html.ActionLink("Détails", "Details", new { id = item.IdOrder })
                @if (User.IsInRole("Administrateur"))
                {
                    @:|
                    @Html.ActionLink("Annuler", "Delete", new { id = item.IdOrder }, new { @class = "text-danger" })
                }
            </td>
        </tr>
    }
</table>

@if (Model.TotalPages > 1)
{
    <nav>
        <ul class="pagination">
            <li class="@(!Model.HasPreviousPage ? "disabled" : "")">
                <a href="@(Model.HasPreviousPage ? Url.Action("Index", new { page = Model.PageIndex - 1, sellerId = ViewBag.CurrentSellerId }) : "#")">«</a>
            </li>
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="@(i == Model.PageIndex ? "active" : "")">
                    <a href="@Url.Action("Index", new { page = i, sellerId = ViewBag.CurrentSellerId })">@i</a>
                </li>
            }
            <li class="@(!Model.HasNextPage ? "disabled" : "")">
                <a href="@(Model.HasNextPage ? Url.Action("Index", new { page = Model.PageIndex + 1, sellerId = ViewBag.CurrentSellerId }) : "#")">»</a>
            </li>
        </ul>
    </nav>
}

<div>
    @Html.ActionLink("Retour", "../Home/Index")
</div>

@section scripts {
<script>
    // Indicateur mode hors-ligne
    function updateOnlineStatus() {
        document.getElementById('offline-banner').style.display = navigator.onLine ? 'none' : 'block';
        document.querySelectorAll('.btn-validate').forEach(function(btn) {
            btn.disabled = !navigator.onLine;
            btn.title = navigator.onLine ? '' : 'Validation impossible en mode hors-ligne';
        });
    }
    window.addEventListener('online',  updateOnlineStatus);
    window.addEventListener('offline', updateOnlineStatus);
    updateOnlineStatus();

    function validateOrder(orderId, btn) {
        if (!navigator.onLine) {
            alert('Validation impossible en mode hors-ligne.');
            return;
        }
        if (!confirm('Valider cette commande ? Cette action est irréversible.')) return;

        btn.disabled = true;
        btn.textContent = 'En cours…';

        fetch('@Url.Action("Validate", "Orders")/' + orderId, {
            method: 'POST',
            headers: {
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? ''
            }
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.error) {
                alert(data.error);
                btn.disabled = false;
                btn.textContent = 'Valider';
            } else {
                location.reload();
            }
        })
        .catch(function() {
            alert('Erreur réseau. Veuillez réessayer.');
            btn.disabled = false;
            btn.textContent = 'Valider';
        });
    }
</script>
@Html.AntiForgeryToken()
}
