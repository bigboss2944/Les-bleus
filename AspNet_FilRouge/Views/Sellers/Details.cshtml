@model Entities.Seller

@{
    ViewBag.Title = "Détails du vendeur";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Détails du vendeur</h2>

<div>
    <h4>Vendeur</h4>
    <hr />
    <dl class="dl-horizontal">
        <dt>Nom</dt>
        <dd>@Html.DisplayFor(model => model.LastName)</dd>
        <dt>Prénom</dt>
        <dd>@Html.DisplayFor(model => model.FirstName)</dd>
        <dt>Email</dt>
        <dd>@Html.DisplayFor(model => model.Email)</dd>
        <dt>Téléphone</dt>
        <dd>@Html.DisplayFor(model => model.PhoneNumber)</dd>
        <dt>Rôle</dt>
        <dd>@Html.DisplayFor(model => model.Role.Name)</dd>
        <dt>Boutique</dt>
        <dd>@Html.DisplayFor(model => model.Shop.Name)</dd>
    </dl>
</div>
<p>
    @Html.ActionLink("Modifier", "Edit", new { id = Model.Id }) |
    @Html.ActionLink("Retour à la liste", "Index")
</p>
