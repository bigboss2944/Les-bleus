@model IEnumerable<AspNet_FilRouge.Models.Order>

@{
    ViewBag.Title = "Commandes";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Commandes — Tous vendeurs</h2>

<p>
    @Html.ActionLink("Nouvelle commande", "Create", null, new { @class = "btn btn-primary" })
</p>

<div id="offline-banner" class="alert alert-warning" style="display:none;">
    <strong>Mode hors-ligne :</strong> la validation de commande est désactivée. Reconnectez-vous au réseau pour valider.
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Date</th>
            <th>Vendeur</th>
            <th>Client</th>
            <th>Boutique</th>
            <th>Mode paiement</th>
            <th>Produits</th>
            <th>Total (€)</th>
            <th>Statut</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        float subtotal = item.Bicycles?.Sum(b => b.FreeTaxPrice) ?? 0f;
        float afterDiscount = subtotal * (1 - item.Discount / 100f);
        float total = afterDiscount * (1 + item.Tax / 100f) + item.ShippingCost;
        <tr>
            <td>@item.Date.ToString("dd/MM/yyyy HH:mm")</td>
            <td>@(item.Seller != null ? $"{item.Seller.FirstName} {item.Seller.LastName}" : "—")</td>
            <td>@(item.Customer != null ? $"{item.Customer.FirstName} {item.Customer.LastName}" : "—")</td>
            <td>@(item.Shop?.Nameshop ?? "—")</td>
            <td>@(item.PayMode ?? "—")</td>
            <td>@(item.Bicycles?.Count ?? 0)</td>
            <td>@total.ToString("F2")</td>
            <td>
                @if (item.IsValidated)
                {
                    <span class="label label-success">Validée</span>
                }
                else
                {
                    <span class="label label-default">En cours</span>
                }
            </td>
            <td>
                @Html.ActionLink("Détails", "Details", new { id = item.IdOrder }) |
                @if (!item.IsValidated)
                {
                    @Html.ActionLink("Modifier", "Edit", new { id = item.IdOrder })
                    <text> | </text>
                    <button type="button" class="btn btn-xs btn-success btn-validate"
                            data-order-id="@item.IdOrder"
                            onclick="validateOrder(@item.IdOrder, this)">
                        Valider
                    </button>
                    <text> | </text>
                }
                @Html.ActionLink("Supprimer", "Delete", new { id = item.IdOrder })
            </td>
        </tr>
    }
    </tbody>
</table>

<div>
    @Html.ActionLink("Retour", "../Home/Index")
</div>

@section scripts {
<script>
    // Indicateur mode hors-ligne
    function updateOnlineStatus() {
        document.getElementById('offline-banner').style.display = navigator.onLine ? 'none' : 'block';
        document.querySelectorAll('.btn-validate').forEach(function(btn) {
            btn.disabled = !navigator.onLine;
            btn.title = navigator.onLine ? '' : 'Validation impossible en mode hors-ligne';
        });
    }
    window.addEventListener('online',  updateOnlineStatus);
    window.addEventListener('offline', updateOnlineStatus);
    updateOnlineStatus();

    function validateOrder(orderId, btn) {
        if (!navigator.onLine) {
            alert('Validation impossible en mode hors-ligne.');
            return;
        }
        if (!confirm('Valider cette commande ? Cette action est irréversible.')) return;

        btn.disabled = true;
        btn.textContent = 'En cours…';

        fetch('@Url.Action("Validate", "Orders")/' + orderId, {
            method: 'POST',
            headers: {
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? ''
            }
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.error) {
                alert(data.error);
                btn.disabled = false;
                btn.textContent = 'Valider';
            } else {
                location.reload();
            }
        })
        .catch(function() {
            alert('Erreur réseau. Veuillez réessayer.');
            btn.disabled = false;
            btn.textContent = 'Valider';
        });
    }
</script>
@Html.AntiForgeryToken()
}
