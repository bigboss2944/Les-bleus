@model AspNet_FilRouge.Models.BicycleOrdersViewModel

<div class="row mb-3">
    @Html.LabelFor(model => model.Bicycles, htmlAttributes: new { @class = "col-md-2 col-form-label" })
    <div class="col-md-10">
        @Html.DropDownListFor(x => x.Bicycles,
            new SelectList(Model.Bicycles, "Id", "Reference"),
            "Référence du vélo",
            new { @class = "form-control", Name = "BicycleId" })
    </div>
</div>
